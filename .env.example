# =============================================================================
# Gathera - Root Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# ── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./database.sqlite  # SQLite file path (development)

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Frontend URL (used by backend for CORS/OAuth redirects) ─────────────────
FRONTEND_URL=http://localhost:3000

# ── Ports ────────────────────────────────────────────────────────────────────
PORT=3000                     # Backend API port
IMAGE_SERVICE_PORT=4000       # Image service port

# ── Sentry (Error Monitoring) ───────────────────────────────────────────────
SENTRY_DSN=                   # https://xxxxx@yyyy.ingest.sentry.io/zzzzz

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=nodemailer     # sendgrid | aws-ses | nodemailer
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@gatherraa.com

# SendGrid-specific (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@gatherraa.com
SENDGRID_FROM_NAME=Gatheraa
SENDGRID_WEBHOOK_URL=

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@gatherraa.com

# ── AWS / S3 ─────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=gatherraa-uploads
AWS_SES_FROM_EMAIL=noreply@gatherraa.com
AWS_SES_CONFIG_SET=default

# ── CDN ──────────────────────────────────────────────────────────────────────
CDN_URL=                      # e.g., https://cdn.gatherraa.com
CDN_PROVIDER=cloudinary       # cloudinary | local

# ── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760        # 10MB
MAX_TOTAL_SIZE=52428800       # 50MB
USE_S3=false                  # true | false

# ── JWT / Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
REFRESH_TOKEN_SECRET=change-me-to-another-random-secret
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:3000

# ── Auth Service ─────────────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:4000

# ── Analytics ────────────────────────────────────────────────────────────────
ANALYTICS_API_KEY=
USERS_API_ENDPOINT=http://localhost:3001/api/users
EVENTS_API_ENDPOINT=http://localhost:3002/api/events
ANALYTICS_API_ENDPOINT=http://localhost:3003/api/analytics

# ── API Servers (for API Gateway / Rate Limiting) ───────────────────────────
API_SERVER_1=http://localhost:3001
API_SERVER_2=http://localhost:3002
API_SERVER_3=http://localhost:3003

# ── Seed / Anonymization ────────────────────────────────────────────────────
FORCE_SEED=                   # Set to 1 to force seeding in production
FORCE_ANONYMIZE=              # Set to 1 to force anonymization in non-production

# ── Stellar / Soroban ───────────────────────────────────────────────────────
SOROBAN_NETWORK=testnet       # testnet | futurenet | mainnet
SOROBAN_ACCOUNT_SECRET=       # Stellar secret key
INFURA_PROJECT_ID=            # Placeholder for Ethereum interoperability
