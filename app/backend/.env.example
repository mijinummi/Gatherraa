# =============================================================================
# Gathera Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# ── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000                     # API server port

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./database.sqlite  # SQLite file path (development fallback)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=gatherraa

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Frontend URL (for CORS and OAuth redirects) ─────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. credentials are only passed for listed origins.
ALLOWED_ORIGINS=http://localhost:3000

# ── JWT / Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
REFRESH_TOKEN_SECRET=change-me-to-another-random-secret
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:3000

# ── Auth Service URL ─────────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:4000

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=nodemailer     # sendgrid | aws-ses | nodemailer
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@gatherraa.com

# SendGrid-specific (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@gatherraa.com
SENDGRID_FROM_NAME=Gatheraa
SENDGRID_WEBHOOK_URL=

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@gatherraa.com

# ── AWS / S3 ─────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=gatherraa-uploads
AWS_SES_FROM_EMAIL=noreply@gatherraa.com
AWS_SES_CONFIG_SET=default

# ── Sentry (Error Monitoring) ───────────────────────────────────────────────
SENTRY_DSN=                   # https://xxxxx@yyyy.ingest.sentry.io/zzzzz

# ── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760        # 10MB
MAX_TOTAL_SIZE=52428800       # 50MB
CDN_PROVIDER=cloudinary       # cloudinary | local
CDN_BASE_URL=http://localhost:3000/uploads

# ── Analytics ────────────────────────────────────────────────────────────────
ANALYTICS_API_KEY=
USERS_API_ENDPOINT=http://localhost:3001/api/users
EVENTS_API_ENDPOINT=http://localhost:3002/api/events
ANALYTICS_API_ENDPOINT=http://localhost:3003/api/analytics

# ── API Servers (for API Gateway / Rate Limiting) ───────────────────────────
API_SERVER_1=http://localhost:3001
API_SERVER_2=http://localhost:3002
API_SERVER_3=http://localhost:3003

# ── Seed / Anonymization ────────────────────────────────────────────────────
FORCE_SEED=                   # Set to 1 to force seeding in production
FORCE_ANONYMIZE=              # Set to 1 to force anonymization in non-production
