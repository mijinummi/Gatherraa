# =============================================================================
# Gathera Frontend - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# Next.js loads .env.local automatically in development.

# ── API Configuration ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Auth Service ─────────────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:4000

# ── Payments (Paystack) ─────────────────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# ── WebSocket / Realtime ────────────────────────────────────────────────────
NEXT_PUBLIC_RECOMMENDATIONS_WS_URL=ws://localhost:4000

# ── Bundle Analyzer ─────────────────────────────────────────────────────────
ANALYZE=false                 # Set to true to analyze bundle size
