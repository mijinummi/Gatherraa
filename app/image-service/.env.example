# =============================================================================
# Gathera Image Service - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ── S3 Storage ──────────────────────────────────────────────────────────────
USE_S3=false                  # true | false
AWS_REGION=us-east-1
AWS_S3_BUCKET=gatherraa-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CDN_URL=                      # e.g., https://cdn.gatherraa.com
